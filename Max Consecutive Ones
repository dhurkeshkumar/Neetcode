public class Solution {
    public int findMaxConsecutiveOnes(int[] nums) {
        int n = nums.length, c = 0;
        for (int i = 0; i < n; i++) {
            int co = 0;
            for (int j = i; j < n; j++) {
                if (nums[j] == 0) break;
                co++;
            }
           c = Math.max(c, co);
        }
        return c;
    }
}
